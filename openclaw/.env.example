# ─── Provider API Keys (at least one required) ──────────────────────────────
# Anthropic (primary when present — recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (primary if no Anthropic key)
# OPENAI_API_KEY=sk-your-key-here

# OpenRouter (primary if no Anthropic/OpenAI key)
# OPENROUTER_API_KEY=sk-or-your-key-here

# Google Gemini
# GOOGLE_API_KEY=your-key-here

# Groq (Llama models)
# GROQ_API_KEY=your-key-here

# ─── Gateway Auth ────────────────────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-to-a-secure-password
OPENCLAW_GATEWAY_TOKEN=generate-a-random-token-here

# ─── Optional ────────────────────────────────────────────────────────────────
# Browser sidecar for web browsing capabilities
# BROWSER_CDP_URL=ws://chrome:3000

# User/group IDs (match your host user to avoid permission issues)
# PUID=1000
# PGID=1000
